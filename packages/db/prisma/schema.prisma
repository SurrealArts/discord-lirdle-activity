generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id
  currentStreak Int       @default(0)
  maxStreak     Int       @default(0)
  gamesPlayed   Int       @default(0)
  wins          Int       @default(0)
  seed          String    @default(uuid())
  sessions      Session[]
  guilds        UserGuild[]
}

model UserGuild {
  userId  String
  guildId String

  user User @relation(fields: [userId], references: [id])

  @@id([userId, guildId])
  @@index([guildId])
}

model DailyWord {
  date     String    @id
  word     String
  sessions Session[]
}

model GuildConfig {
  guildId              String   @id
  activeChannelId      String
  leaderboardChannelId String?
  monthlyStatsEnabled  Boolean  @default(false)
  // leaderboardPing      Boolean  @default(false)
}

model Session {
  id          String    @id @default(uuid())
  userId      String
  guildId     String?
  date        String
  guesses     String
  tries       Int       @default(0)
  won         Boolean   @default(false)
  completedAt DateTime  @default(now())
  updatedAt   DateTime  @default(now())      @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  dailyWord DailyWord @relation(fields: [date], references: [date])

  @@unique([userId, date])
  @@index([guildId, date])
}