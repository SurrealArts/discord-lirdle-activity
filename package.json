{
  "name": "discord-lirdle-activity",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:bot": "pnpm --filter @lirdle/bot run dev",
    "dev:web": "pnpm --filter @lirdle/web run dev",
    "dev": "pnpm --parallel --filter @lirdle/* run dev",
    "force-reset-db": "pnpm --filter @lirdle/db exec prisma db push --force-reset && pnpm --filter @lirdle/db exec prisma generate",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prettier-write": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "cron:daily-lb": "pnpm --filter @lirdle/bot run cron:daily",
    "cron:monthly-lb": "pnpm --filter @lirdle/bot run cron:monthly"
  },
  "keywords": [],
  "author": "anato",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "dotenv-flow": "^4.1.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3"
  }
}
